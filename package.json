{
  "name": "joshre.github.io",
  "version": "1.0.0",
  "repository": "https://github.com/joshre/joshre.github.io.git",
  "author": "Josh Reeder-Esparza <joshre@me.com>",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "yarn tailwindcss -i _css/input.css -o css/output.css --minify && node build.js && bundle exec jekyll build",
    "watch": "concurrently \"./build.js --watch\" \"bundle exec jekyll serve --livereload\" \"yarn tailwindcss -i _css/input.css -o css/output.css --minify --watch\"",
    "lint": "concurrently \"yarn lint:tw\" \"yarn lint:format\"",
    "lint:tw": "rustywind --check-formatted '_layouts/**/*.html' '_includes/**/*.html' '_css/**/*.css'",
    "lint:tw:fix": "rustywind '_layouts/**/*.html' '_includes/**/*.html' '_css/**/*.css'",
    "lint:format": "prettier --check '**/*.{html,css,js,json,md}' --ignore-path .gitignore",
    "format": "prettier --write '**/*.{html,css,js,json,md}' --ignore-path .gitignore"
  },
  "dependencies": {
    "@tailwindcss/cli": "*",
    "@tailwindcss/typography": "*",
    "concurrently": "*",
    "estrella": "*",
    "tailwindcss": "*"
  },
  "devDependencies": {
    "prettier": "*",
    "prettier-plugin-tailwindcss": "*",
    "rustywind": "*"
  }
}
